{
  "schemaVersion": 1,
  "id": "honeybees",
  "version": "${version}",

  "name": "HoneyBees",
  "description": "Adds real-size bees, beehives, honey glazed food, honey sweets and honeycomb blocks. It's a standalone version of Foodies 1.1 update features.",
  "authors": [
    "Sayuzaur"
  ],
  "contact": {
    "homepage": "",
    "sources": "https://github.com/Sayuzaur/honeybees"
  },

  "license": "LGPL-3.0-or-later",
  "icon": "assets/honeybees/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      "io.github.sayuzaur.honeybees.events.init.BlockListener",
      "io.github.sayuzaur.honeybees.events.init.ItemListener",
      "io.github.sayuzaur.honeybees.events.init.FeatureListener"
    ],
    "stationapi:event_bus_client": [
    ],
    "stationapi:event_bus_server": [
    ],
    "bhcreative:event_bus": [
      "io.github.sayuzaur.honeybees.events.init.CreativeListener"
    ],
    "gcapi3": [
      "io.github.sayuzaur.honeybees.HoneyBees"
    ]
  },
  "mixins": [
    "honeybees.mixins.json"
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "farn_util": ">=3.3.2-babric",
    "stationapi": ">=2.0.0-alpha.6.2"
  }
}
